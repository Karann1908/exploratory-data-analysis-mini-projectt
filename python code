import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np

# Load the dataset
df = pd.read_csv('population.csv')
latest_year = df['Year'].max()

# Explicitly define Main Countries to focus analysis
main_countries = [
    'India', 'China', 'United States', 'Indonesia', 'Pakistan',
    'Nigeria', 'Brazil', 'Bangladesh', 'Russian Federation', 'Ethiopia',
    'Mexico', 'Japan', 'Philippines', 'Egypt, Arab Rep.', 'Vietnam'
]
main_df = df[df['Country Name'].isin(main_countries)].copy()
sns.set_theme(style="whitegrid")

# --- GENERATING 12 VISUALIZATIONS ---

# 1. Line Chart: Top 5 Giants
plt.figure(figsize=(10, 5))
top5 = ['India', 'China', 'United States', 'Indonesia', 'Pakistan']
sns.lineplot(data=main_df[main_df['Country Name'].isin(top5)], x='Year', y='Value', hue='Country Name', marker='o', markersize=3)
plt.title('1. Population Trends of Global Giants (1960-2024)')
plt.savefig('1_line.png')

# 2. Bar Chart: Ranking of 15 Main Countries
plt.figure(figsize=(10, 6))
sns.barplot(data=main_df[main_df['Year'] == latest_year].sort_values('Value', ascending=False), x='Value', y='Country Name', hue='Country Name', palette='viridis', legend=False)
plt.title(f'2. Population Ranking of Main Countries ({latest_year})')
plt.savefig('2_bar.png')

# 3. Histogram: Global Distribution with Focus
plt.figure(figsize=(10, 5))
aggregates = ['World', 'High income', 'Middle income', 'Low income']
all_countries = df[~df['Country Name'].isin(aggregates)]
sns.histplot(all_countries[all_countries['Year'] == latest_year]['Value'], bins=30, kde=True, color='gray')
plt.yscale('log')
plt.title('3. Global Population Distribution (Log Scale)')
plt.savefig('3_hist.png')

# 4. Box Plot: Population Variability by Era
main_df['Era'] = pd.cut(main_df['Year'], bins=[1959, 1980, 2000, 2024], labels=['1960-1980', '1981-2000', '2001-2024'])
plt.figure(figsize=(10, 5))
sns.boxplot(data=main_df, x='Era', y='Value', hue='Era', palette='pastel', legend=False)
plt.yscale('log')
plt.title('4. Population Variability of Main Countries by Era')
plt.savefig('4_box.png')

