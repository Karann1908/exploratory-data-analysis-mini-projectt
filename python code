plt.title(f'Global Population Share ({latest_year})\nTop 10 Main Countries vs. Others', fontsize=16, pad=20)
plt.savefig('main_countries_pie_chart.png', dpi=300, bbox_inches='tight')
plt.show()

# 6. Scatter Plot: Growth Rate vs 1960 Size
growth_data = []
for country in main_countries:
    try:
        y1960 = main_df[(main_df['Country Name'] == country) & (main_df['Year'] == 1960)]['Value'].values[0]
        y2024 = main_df[(main_df['Country Name'] == country) & (main_df['Year'] == latest_year)]['Value'].values[0]
        rate = (y2024 - y1960) / y1960 * 100
        growth_data.append({'Country': country, '1960_Pop': y1960, 'Growth_Rate': rate})
    except: pass
growth_df = pd.DataFrame(growth_data)
plt.figure(figsize=(10, 5))
sns.scatterplot(data=growth_df, x='1960_Pop', y='Growth_Rate', hue='Country', s=150)
plt.xscale('log')
plt.title('6. Growth Rate (%) vs Population in 1960')
plt.savefig('6_scatter.png')

# 7. Heatmap: Annual Growth Rate % (Last 20 Years)
pivot_growth = main_df[main_df['Country Name'].isin(top5)].pivot(index='Country Name', columns='Year', values='Value').pct_change(axis=1).dropna(axis=1) * 100
plt.figure(figsize=(12, 4))
sns.heatmap(pivot_growth.iloc[:, -20:], annot=True, cmap='RdYlGn', fmt=".1f")
plt.title('7. Annual Growth Rate % (Last 20 Years)')
plt.savefig('7_heat.png')

# 8. Area Chart: Cumulative Growth of 5 Major Nations
plt.figure(figsize=(10, 5))
area_data = main_df[main_df['Country Name'].isin(['India', 'China', 'United States', 'Brazil', 'Russian Federation'])].pivot(index='Year', columns='Country Name', values='Value')
area_data.plot.area(ax=plt.gca(), alpha=0.4)
plt.title('8. Cumulative Growth of 5 Major Nations')
plt.savefig('8_area.png')

# 9. Violin Plot: Density Shift of Main Countries
plt.figure(figsize=(10, 5))
sns.violinplot(data=main_df[main_df['Year'].isin([1960, 1990, 2024])], x='Year', y='Value', palette='muted', hue='Year', legend=False)
plt.yscale('log')
plt.title('9. Density Shift of Main Countries (1960-2024)')
plt.savefig('9_violin.png')

# 10. KDE Plot: Population Concentration
plt.figure(figsize=(10, 5))
for c in ['Nigeria', 'Pakistan', 'Russian Federation']:
    sns.kdeplot(main_df[main_df['Country Name'] == c]['Value'], label=c, fill=True)
plt.title('10. Population Concentration (Fast vs Slow Growth)')
plt.legend()
plt.savefig('10_kde.png')

plt.show()
